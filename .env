DRIVER=~fastapi
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO

# OneBot 配置（NapCat/Lagrange 的 WebSocket 地址）
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# 超级用户 QQ 号（管理员）
SUPERUSERS=["123456789"]

# 工会战 BOT 配置
GW_MAX_KNIVES=3              # 每人每天最大刀数
GW_REMIND_HOUR=21            # 催刀提醒小时（24小时制）
GW_REMIND_MINUTE=0           # 催刀提醒分钟
GW_GROUP_ID=987654321        # 工会群号
